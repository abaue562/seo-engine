# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
MODEL=claude-sonnet-4-20250514

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8900
LOG_LEVEL=info
SITE_BASE_URL=https://your-site.com
SITE_HOST=your-site.com

# ── Task queue ───────────────────────────────────────────────────────────────
# Redis connection (used by Celery for background tasks)
REDIS_URL=redis://localhost:6379/0
CELERY_CONCURRENCY=4

# ── Google ───────────────────────────────────────────────────────────────────
GSC_CREDENTIALS_PATH=config/gsc_credentials.json
GSC_TOKEN_PATH=config/gsc_token.json
GA4_PROPERTY_ID=G-XXXXXXXXXX
GA4_CREDENTIALS_PATH=config/ga4_credentials.json
# Free: 25K requests/day without key. Get key at console.cloud.google.com
GOOGLE_PAGESPEED_API_KEY=

# ── Bing ─────────────────────────────────────────────────────────────────────
# Get at: bing.com/webmasters → API Access
BING_WEBMASTER_API_KEY=

# ── DataForSEO ───────────────────────────────────────────────────────────────
# Get at: dataforseo.com — provides keyword volume, SERP data, backlinks
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Ahrefs ───────────────────────────────────────────────────────────────────
# Get at: ahrefs.com/api — domain rating, backlinks, organic keywords
AHREFS_API_TOKEN=

# ── Content quality ──────────────────────────────────────────────────────────
# Get at: originality.ai — AI content detection
ORIGINALITY_API_KEY=
AI_SCORE_THRESHOLD=0.8

# ── IndexNow ─────────────────────────────────────────────────────────────────
# Generate any random GUID/string as your key.
# Place a text file at: https://your-site.com/{INDEXNOW_API_KEY}.txt with the key as content.
INDEXNOW_API_KEY=

# ── Brand / AI citation monitoring ───────────────────────────────────────────
# Get at: brandmentions.com
BRANDMENTIONS_API_KEY=

# ── Alerts ───────────────────────────────────────────────────────────────────
# Slack: create incoming webhook → paste URL here
# Discord: channel settings → Integrations → Webhooks → copy URL
# Telegram: use bot webhook URL
ALERT_WEBHOOK_URL=

# ── Database ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJxxx

# ── Autonomous runner ─────────────────────────────────────────────────────────
AUTONOMOUS_MODE=shadow          # shadow | assisted | autonomous
CONFIDENCE_THRESHOLD=0.7
MAX_DAILY_EXECUTIONS=5
RUNNER_LOOP_HOURS=24

# ── Data freshness (days) ─────────────────────────────────────────────────────
FRESHNESS_RANKINGS=30
FRESHNESS_REVIEWS=90
FRESHNESS_TRAFFIC=90

# ── Publishing network ────────────────────────────────────────────────────────

# Your WordPress site (auto-publish pages + posts)
WP_URL=https://your-site.com
WP_USER=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx
# draft = review before publishing; publish = auto-live
WP_PUBLISH_STATUS=draft

# Medium (auto-publish articles with backlinks)
# Get token: medium.com/me/settings/security
MEDIUM_TOKEN=
MEDIUM_PUBLISH_STATUS=draft

# ── Link injection ─────────────────────────────────────────────────────────────
# How many existing WP posts to scan for inbound link opportunities per new page
LINK_INJECT_MAX_POSTS=20
# Minimum keyword overlap score (0.0–1.0) to inject a link
LINK_INJECT_RELEVANCE_THRESHOLD=0.3

# Blogger/Blogspot (satellite blog)
BLOGGER_BLOG_ID=

# WordPress.com (free blog network)
WP_COM_SITE=yourblog.wordpress.com
WP_COM_TOKEN=

# Tumblr (content syndication)
TUMBLR_BLOG=yourblog
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
TUMBLR_TOKEN=
TUMBLR_SECRET=

# Pinterest (visual pins with backlinks)
PINTEREST_TOKEN=
PINTEREST_BOARD=
